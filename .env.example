# .env.example — template for local development
# Copy values into backend/.env or set as environment variables on your host.
# DO NOT commit real secret values. This file is a template only.

# -----------------------------
# Backend (server-side) env vars
# -----------------------------
# Either set `OPENAI_API_KEY` (OpenAI) or `OPENROUTER_API_KEY` (OpenRouter).
# If using OpenRouter the backend maps `OPENROUTER_API_KEY` -> `OPENAI_API_KEY`.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Model and optional base URL overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=
OPENROUTER_BASE_URL=https://api.openrouter.ai/v1

# Vapi voice backend private key (server-only)
VAPI_PRIVATE_KEY=

# Supabase (service role key — server-only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Server options
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

# -----------------------------
# Frontend (put these in `frontend/.env.local`)
# -----------------------------
# Public keys for client-side usage. Do not put secret service role keys here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3001/api
VITE_VAPI_PUBLIC_KEY=
VITE_VAPI_ASSISTANT_ID=
NEXT_PUBLIC_ELEVENLABS_API_KEY=
